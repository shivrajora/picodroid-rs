[submodule "third_party/FreeRTOS-Kernel"]
	path = third_party/FreeRTOS-Kernel
	url = https://github.com/FreeRTOS/FreeRTOS-Kernel.git
[submodule "vendor/lvgl"]
	path = vendor/lvgl
	url = https://github.com/lvgl/lvgl.git
[submodule "vendor/freertos-plus-tcp"]
	path = vendor/freertos-plus-tcp
	url = https://github.com/FreeRTOS/FreeRTOS-Plus-TCP.git
[submodule "vendor/cyw43-driver"]
	path = vendor/cyw43-driver
	url = https://github.com/georgerobotics/cyw43-driver.git
