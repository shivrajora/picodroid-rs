{
  "globs": [
    "README.md",
    "CLAUDE.md",
    "ARCHITECTURE.md",
    "CONTRIBUTING.md",
    "LICENSING.md",
    "CLA.md",
    "jvm/README.md",
    "compat/README.md",
    "tools/*/README.md",
    "sdk/shrink-maps/README.md"
  ],
  "ignores": [
    "vendor/**",
    "node_modules/**",
    "build/**",
    "target/**",
    "website/**"
  ],
  "config": {
    "default": true,
    "MD013": false,
    "MD024": { "siblings_only": true },
    "MD029": false,
    "MD033": false,
    "MD041": false,
    "MD046": { "style": "fenced" }
  }
}
