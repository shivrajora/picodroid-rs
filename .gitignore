**/*.rs.bk
.#*
.gdb_history
Cargo.lock
target/

# Downloaded tooling (google-java-format JAR, etc.)
vendor/
# LVGL is a git submodule — must not be ignored
!vendor/lvgl/
!vendor/freertos-plus-tcp/
!vendor/cyw43-driver/
!vendor/cyw43-firmware/

# Build artifacts (compiled classes, packaged APKs)
build/

# Gradle wrapper cache, daemon state, config-cache entries
.gradle/

# Claude Code local settings
.claude/settings.local.json
.claude/scheduled_tasks.lock

# editor files
.vscode/*
!.vscode/*.md
!.vscode/*.svd
!.vscode/launch.json
!.vscode/tasks.json
!.vscode/extensions.json
!.vscode/settings.json