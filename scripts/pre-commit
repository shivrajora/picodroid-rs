#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
SCRIPT_DIR="$REPO_ROOT/scripts"

# shellcheck source=lib.sh
source "$SCRIPT_DIR/lib.sh"

echo "==> Checking Java formatting..."
if ! bash "$REPO_ROOT/scripts/format_java.sh" check; then
  exit 1
fi

echo "==> Linting markdown (markdownlint-cli2)..."
if ! bash "$REPO_ROOT/scripts/lint-md.sh"; then
  echo ""
  echo "ERROR: Markdown lint failed. Run './scripts/lint-md.sh --fix' to"
  echo "       auto-fix, or './scripts/lint-md.sh' to see issues."
  echo "       If deps aren't installed yet: run 'npm install' in the repo root."
  exit 1
fi

echo "==> Checking hil-tests.conf against the source tree..."
if ! bash "$REPO_ROOT/scripts/check-hil-conf.sh"; then
  echo ""
  echo "ERROR: hil-tests.conf references apps or log tags that no longer"
  echo "       exist. Update the affected rows (or ALLOW_TAGS in"
  echo "       scripts/check-hil-conf.sh) so the nightly suites don't go"
  echo "       permanently red."
  exit 1
fi

echo "==> Checking sim/family-rp cfg-gate hygiene..."
# docs/parity-audit.md BLD-02/X2: sim builds keep `family-rp` ACTIVE (the
# board feature chain), so a gate written as not(feature = "family-rp") does
# NOT mean "not the simulator" — it selects the ESP/no-family path. The
# existing occurrences are deliberate cross-family gates; a new one usually
# wants `feature = "sim"` spelled out instead.
FAMRP_GATES=$(grep -rn 'not(feature = "family-rp")' \
  "$REPO_ROOT/platforms/rp/src" "$REPO_ROOT/picodroid-core/src" | wc -l | tr -d ' ')
if [[ "$FAMRP_GATES" != "4" ]]; then
  grep -rn 'not(feature = "family-rp")' \
    "$REPO_ROOT/platforms/rp/src" "$REPO_ROOT/picodroid-core/src" || true
  echo ""
  echo "ERROR: expected exactly 4 'not(feature = \"family-rp\")' cfg gates,"
  echo "       found $FAMRP_GATES. Sim builds activate family-rp, so this"
  echo "       pattern does not exclude the simulator. If the new gate is"
  echo "       genuinely correct for sim builds too, bump the expected count"
  echo "       in scripts/pre-commit and note it under BLD-02 in"
  echo "       docs/parity-audit.md."
  exit 1
fi

echo "==> Type-checking all Java apps (gradle compileJava)..."
if ! (cd "$REPO_ROOT" && ./gradlew compileJava --console=plain); then
  echo ""
  echo "ERROR: Java compilation failed. Fix the errors above before committing."
  exit 1
fi

echo "==> Checking formatting (cargo fmt)..."
if ! cargo fmt -- --check; then
  echo ""
  echo "ERROR: Formatting check failed. Run 'cargo fmt' to fix, then re-stage your changes."
  exit 1
fi

# Build a representative APK once for all clippy / firmware build checks.
echo "==> Building helloworld APK for type-checking..."
bash "$REPO_ROOT/scripts/build-apk.sh" --app helloworld
APK_PATH="$REPO_ROOT/build/apks/helloworld.papk"

# Run clippy for each board target
JOBS="$(cpu_count)"

for board in testbench_rp2040 testbench_rp2350; do
  resolve_board "$board"
  echo "==> Running clippy ($board)..."
  # shellcheck disable=SC2086
  if ! PICODROID_APK_PATH="$APK_PATH" \
       cargo $CARGO_PLUS clippy \
         --manifest-path "$MANIFEST_DIR/Cargo.toml" \
         -p "$PACKAGE" --jobs "$JOBS" --target "$TARGET" --no-default-features \
         --features "$BOARD_FEATURE" -- --deny=warnings; then
    echo ""
    echo "ERROR: Clippy check failed ($board). Fix the warnings above before committing."
    exit 1
  fi
done

HOST_TARGET="$(host_target)"

echo "==> Running clippy (sim)..."
# MANIFEST_DIR/PACKAGE/CARGO_PLUS are still set to testbench_rp2350 from the loop above.
# shellcheck disable=SC2086
if ! PICODROID_APK_PATH="$APK_PATH" \
     cargo $CARGO_PLUS clippy \
       --manifest-path "$MANIFEST_DIR/Cargo.toml" \
       -p "$PACKAGE" --jobs "$JOBS" --target "$HOST_TARGET" --no-default-features \
       --features "sim,board-testbench-rp2350" -- --deny=warnings; then
  echo ""
  echo "ERROR: Clippy check failed (sim). Fix the warnings above before committing."
  exit 1
fi

resolve_board tdeck_plus
echo "==> Running clippy (tdeck_plus)..."
# shellcheck disable=SC2086
if ! PICODROID_APK_PATH="$APK_PATH" \
     cargo $CARGO_PLUS clippy \
       --manifest-path "$MANIFEST_DIR/Cargo.toml" \
       -p "$PACKAGE" --jobs "$JOBS" --target "$TARGET" --no-default-features \
       --features "$BOARD_FEATURE" \
       "${EXTRA_BUILD_ARGS[@]}" -- --deny=warnings; then
  echo ""
  echo "ERROR: Clippy check failed (tdeck_plus). Fix the warnings above before committing."
  exit 1
fi

echo "==> Building..."
if ! bash "$REPO_ROOT/scripts/build.sh" --board testbench_rp2040 --app helloworld; then
  echo ""
  echo "ERROR: Build failed. Fix the errors above before committing."
  exit 1
fi

echo "==> Running clippy (pdb)..."
if ! cargo clippy -p pdb --jobs "$JOBS" --target "$HOST_TARGET" -- --deny=warnings; then
  echo ""
  echo "ERROR: Clippy check failed. Fix the warnings above before committing."
  exit 1
fi

echo "==> Running tests..."
if ! bash "$REPO_ROOT/scripts/test.sh"; then
  echo ""
  echo "ERROR: Tests failed. Fix the failures above before committing."
  exit 1
fi

echo "==> Verifying apply_jvm_env propagation..."
if ! bash "$REPO_ROOT/scripts/test-jvm-env.sh"; then
  echo ""
  echo "ERROR: apply_jvm_env smoke test failed. The [jvm] board.toml parser"
  echo "       in scripts/lib.sh is not propagating values to the right"
  echo "       PICODROID_JVM_* env vars. Fix before committing."
  exit 1
fi

echo "==> All checks passed."
