#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
SCRIPT_DIR="$REPO_ROOT/scripts"

# shellcheck source=lib.sh
source "$SCRIPT_DIR/lib.sh"

echo "==> Checking Java formatting..."
if ! bash "$REPO_ROOT/scripts/format_java.sh" check; then
  exit 1
fi

echo "==> Linting markdown (markdownlint-cli2)..."
if ! bash "$REPO_ROOT/scripts/lint-md.sh"; then
  echo ""
  echo "ERROR: Markdown lint failed. Run './scripts/lint-md.sh --fix' to"
  echo "       auto-fix, or './scripts/lint-md.sh' to see issues."
  echo "       If deps aren't installed yet: run 'npm install' in the repo root."
  exit 1
fi

echo "==> Type-checking all Java apps (gradle compileJava)..."
if ! (cd "$REPO_ROOT" && ./gradlew compileJava --console=plain); then
  echo ""
  echo "ERROR: Java compilation failed. Fix the errors above before committing."
  exit 1
fi

echo "==> Checking formatting (cargo fmt)..."
if ! cargo fmt -- --check; then
  echo ""
  echo "ERROR: Formatting check failed. Run 'cargo fmt' to fix, then re-stage your changes."
  exit 1
fi

# Build a representative APK once for all clippy / firmware build checks.
echo "==> Building helloworld APK for type-checking..."
bash "$REPO_ROOT/scripts/build-apk.sh" --app helloworld
APK_PATH="$REPO_ROOT/build/apks/helloworld.papk"

# Run clippy for each board target
JOBS="$(cpu_count)"

for board in testbench_rp2040 testbench_rp2350; do
  resolve_board "$board"
  echo "==> Running clippy ($board)..."
  if ! PICODROID_APK_PATH="$APK_PATH" \
       cargo clippy --jobs "$JOBS" --target "$TARGET" --no-default-features \
                    --features "$BOARD_FEATURE" -- --deny=warnings; then
    echo ""
    echo "ERROR: Clippy check failed ($board). Fix the warnings above before committing."
    exit 1
  fi
done

HOST_TARGET="$(host_target)"

echo "==> Running clippy (sim)..."
if ! PICODROID_APK_PATH="$APK_PATH" \
     cargo clippy --jobs "$JOBS" --target "$HOST_TARGET" --no-default-features \
                  --features "sim,board-testbench-rp2350" -- --deny=warnings; then
  echo ""
  echo "ERROR: Clippy check failed. Fix the warnings above before committing."
  exit 1
fi

echo "==> Building..."
if ! bash "$REPO_ROOT/scripts/build.sh" --board testbench_rp2040 --app helloworld; then
  echo ""
  echo "ERROR: Build failed. Fix the errors above before committing."
  exit 1
fi

echo "==> Running clippy (pdb)..."
if ! cargo clippy -p pdb --jobs "$JOBS" --target "$HOST_TARGET" -- --deny=warnings; then
  echo ""
  echo "ERROR: Clippy check failed. Fix the warnings above before committing."
  exit 1
fi

echo "==> Running tests..."
if ! bash "$REPO_ROOT/scripts/test.sh"; then
  echo ""
  echo "ERROR: Tests failed. Fix the failures above before committing."
  exit 1
fi

echo "==> All checks passed."
